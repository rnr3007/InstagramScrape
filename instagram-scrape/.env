# Configuration for the Appium server
APPIUM_HOST=host.internal.docker
APPIUM_PORT=4723

# Configuration for the Android device
# Get the device ID using command [adb devices]
ANDROID_ID=0925537312004934
# Get the default launcher using command [adb shell cmd shortcut get-default-launcher]
ANDROID_DEFAULT_LAUNCHER="ComponentInfo{com.transsion.hilauncher.upgrade/com.android.quickstep.recents_ui_overrides.src.com.android.launcher3.uioverrides.QuickstepLauncher}"

# Configuration for the exposed API
API_PORT=3000

# configuration for the app accessibility id that want to be automated
APP_ID=Instagram
APP_PKG=com.instagram.android

# Configuration for the random swipe constants
# The higher the constant number, the random value will be more likely goes into the middle of the screen
RANDOM_CONSTANTS_X=5 
RANDOM_CONSTANTS_Y=9

# Configuration for the save file path
OUTPUT_FILE=./output.csv